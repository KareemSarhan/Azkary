[
  {
    "sura_no": 2,
    "aya_no": 255,
    "aya_text_uthmani_pua": "\u200f\ue94f\u200f\ue490 \u200f\ue497 \u200f\ue361\u200f\ue7f2\u200f\ue316 \u200f\ue361\u200f\ue494 \u200f\ue0c7\u200f\ue309 \u200f\ue338\u200f\ue0ae\u200f\ue5a8 \u200f\ue338\u200f\ue93d\u200f\ue178\u200f\ue1b3\u200f\ue30f\u200f\ue44e\u200f\ue003 \u200f\ue496 \u200f\ue030\u200f\ue1ce\u200f\ue04f\u200f\ue230\u200f\ue465\u200f\ue342 \u200f\ue056\u200f\ue1a2\u200f\ue327 \u200f\ue475\u200f\ue496 \u200f\ue0bf\u200f\ue30b\u200f\ue44b\u200f\ue003 \u200f\ue7cd\u200f\ue342 \u200f\ue0b5\u200f\ue1d9 \u200f\ue5e1 \u200f\ue338\u200f\ue0af\u200f\ue11b\u200f\ue828\u200f\ue84b\u200f\ue388 \u200f\ue475\u200f\ue0b5\u200f\ue1d9 \u200f\ue5e1 \u200f\ue338\u200f\ue4a5\u200f\ue8ff\u200f\ue3fd\u200f\ue00e \u200f\ue0b5\u200f\ue2fe \u200f\ue3c1\u200f\ue337 \u200f\ue338\u200f\ue7b1\u200f\ue341 \u200f\ue864\u200f\ue12b\u200f\ue16c\u200f\ue294 \u200f\ue07c\u200f\ue1a6\u200f\ue221\u200f\ue465\u200f\ue343 \u200f\ue361\u200f\ue494 \u200f\ue949\u200f\ue3bd\u200f\ue0bd\u200f\ue313\u200f\ue344\u200f\ue01b \u200f\ue0d8\u200f\ue15e\u200f\ue189\u200f\ue2e6 \u200f\ue0b5\u200f\ue1d9 \u200f\ue026\u200f\ue704 \u200f\ue914\u200f\ue0dc\u200f\ue21d\u200f\ue0de\u200f\ue1aa\u200f\ue2ec \u200f\ue475\u200f\ue0b5\u200f\ue1d9 \u200f\ue050\u200f\ue18a\u200f\ue16c\u200f\ue1ab\u200f\ue2ec\u200f\ue001 \u200f\ue475\u200f\ue496 \u200f\ue509\u200f\ue1c0\u200f\ue146\u200f\ue30f\u200f\ue45e \u200f\ue855\u200f\ue5b7\u200f\ue349 \u200f\ue0b0\u200f\ue2fb \u200f\ue07c\u200f\ue18a\u200f\ue191\u200f\ue313\u200f\ue345 \u200f\ue361\u200f\ue494 \u200f\ue024\u200f\ue194\u200f\ue1d9 \u200f\ue05d\u200f\ue1d6\u200f\ue350\u200f\ue00c \u200f\ue475\u200f\ue056\u200f\ue295 \u200f\ue0a0\u200f\ue249\u200f\ue056\u200f\ue1b3\u200f\ue315 \u200f\ue338\u200f\ue0af\u200f\ue11b\u200f\ue828\u200f\ue84b\u200f\ue388 \u200f\ue475\u200f\ue338\u200f\ue4a5\u200f\ue8ff\u200f\ue3fb\u200f\ue00d \u200f\ue475\u200f\ue496 \u200f\ue8ad\u200f\ue30f\u200f\ue3b9\u200f\ue465\u200f\ue342 \u200f\ue045\u200f\ue16e\u200f\ue152\u200f\ue1ab\u200f\ue194\u200f\ue1d9\u200f\ue00c \u200f\ue475\u200f\ue0c7\u200f\ue309 \u200f\ue338\u200f\ue0ae\u200f\ue15c\u200f\ue658 \u200f\ue338\u200f\ue0ae\u200f\ue15c\u200f\ue151\u200f\ue1c0\u200f\ue2e6 \u200f\uea58",
    "aya_text_emlaey": "\u0627\u0644\u0644\u0647 \u0644\u0627 \u0625\u0644\u0647 \u0625\u0644\u0627 \u0647\u0648 \u0627\u0644\u062d\u064a \u0627\u0644\u0642\u064a\u0648\u0645 \u0644\u0627 \u062a\u0623\u062e\u0630\u0647 \u0633\u0646\u0629 \u0648\u0644\u0627 \u0646\u0648\u0645 \u0644\u0647 \u0645\u0627 \u0641\u064a \u0627\u0644\u0633\u0645\u0648\u0627\u062a \u0648\u0645\u0627 \u0641\u064a \u0627\u0644\u0623\u0631\u0636 \u0645\u0646 \u0630\u0627 \u0627\u0644\u0630\u064a \u064a\u0634\u0641\u0639 \u0639\u0646\u062f\u0647 \u0625\u0644\u0627 \u0628\u0625\u0630\u0646\u0647 \u064a\u0639\u0644\u0645 \u0645\u0627 \u0628\u064a\u0646 \u0623\u064a\u062f\u064a\u0647\u0645 \u0648\u0645\u0627 \u062e\u0644\u0641\u0647\u0645 \u0648\u0644\u0627 \u064a\u062d\u064a\u0637\u0648\u0646 \u0628\u0634\u064a\u0621 \u0645\u0646 \u0639\u0644\u0645\u0647 \u0625\u0644\u0627 \u0628\u0645\u0627 \u0634\u0627\u0621 \u0648\u0633\u0639 \u0643\u0631\u0633\u064a\u0647 \u0627\u0644\u0633\u0645\u0648\u0627\u062a \u0648\u0627\u0644\u0623\u0631\u0636 \u0648\u0644\u0627 \u064a\u0626\u0648\u062f\u0647 \u062d\u0641\u0638\u0647\u0645\u0627 \u0648\u0647\u0648 \u0627\u0644\u0639\u0644\u064a \u0627\u0644\u0639\u0638\u064a\u0645"
  },
  {
    "sura_no": 2,
    "aya_no": 285,
    "aya_text_uthmani_pua": "\u200f\ue350\u200f\ue337\u200f\ue0b5\u200f\ue2f6 \u200f\ue338\u200f\ue0af\u200f\ue238\u200f\ue057\u200f\ue30f\u200f\ue443 \u200f\ue024\u200f\ue194\u200f\ue1d6 \u200f\ue360\u200f\ue0c4\u200f\ue252\u200f\ue442 \u200f\ue361\u200f\ue792\u200f\ue313 \u200f\ue0b3\u200f\ue2fe \u200f\ue3c7\u200f\ue020\u200f\ue313\u200f\ue344 \u200f\ue475\u200f\ue338\u200f\ue0ae\u200f\ue192\u200f\ue32d\u200f\ue0b3\u200f\ue1a0\u200f\ue30f\u200f\ue45e\u200f\ue003 \u200f\ue733 \u200f\ue350\u200f\ue337\u200f\ue0b5\u200f\ue2f6 \u200f\ue024\u200f\ue1ca\u200f\ue48e \u200f\ue475\u200f\ue0b5\u200f\ue833\u200f\ue1c1\u200f\ue182\u200f\ue0f1\u200f\ue313\u200f\ue344 \u200f\ue475\u200f\ue0a0\u200f\ue0f2\u200f\ue0e7\u200f\ue313\u200f\ue344 \u200f\ue475\u200f\ue01c\u200f\ue3d2\u200f\ue057\u200f\ue187\u200f\ue313\u200f\ue344 \u200f\ue496 \u200f\ue0be\u200f\ue16c\u200f\ue236\u200f\ue42d \u200f\ue026\u200f\ue704 \u200f\ue35f\u200f\ue047\u200f\ue228 \u200f\ue0b0\u200f\ue2fe \u200f\ue3c8\u200f\ue057\u200f\ue187\u200f\ue313\u200f\ue344\u200f\ue01b \u200f\ue475\u200f\ue097\u200f\ue1d9\u200f\ue0ab\u200f\ue30f\u200f\ue35d \u200f\ue058\u200f\ue191\u200f\ue15e\u200f\ue1a2\u200f\ue1d9 \u200f\ue475\u200f\ue35f\u200f\ue06e\u200f\ue15e\u200f\ue1a2\u200f\ue1d9\u200f\ue00a \u200f\ue084\u200f\ue16e\u200f\ue245\u200f\ue337\u200f\ue0bf\u200f\ue2c4 \u200f\ue3d1\u200f\ue022\u200f\ue1a2\u200f\ue1d9 \u200f\ue8fd\u200f\ue792\u200f\ue2c4 \u200f\ue338\u200f\ue0ae\u200f\ue194\u200f\ue130\u200f\ue684\u200f\ue698 \u200f\uea76",
    "aya_text_emlaey": "\u0622\u0645\u0646 \u0627\u0644\u0631\u0633\u0648\u0644 \u0628\u0645\u0627 \u0623\u0646\u0632\u0644 \u0625\u0644\u064a\u0647 \u0645\u0646 \u0631\u0628\u0647 \u0648\u0627\u0644\u0645\u0624\u0645\u0646\u0648\u0646 \u0643\u0644 \u0622\u0645\u0646 \u0628\u0627\u0644\u0644\u0647 \u0648\u0645\u0644\u0627\u0626\u0643\u062a\u0647 \u0648\u0643\u062a\u0628\u0647 \u0648\u0631\u0633\u0644\u0647 \u0644\u0627 \u0646\u0641\u0631\u0642 \u0628\u064a\u0646 \u0623\u062d\u062f \u0645\u0646 \u0631\u0633\u0644\u0647 \u0648\u0642\u0627\u0644\u0648\u0627 \u0633\u0645\u0639\u0646\u0627 \u0648\u0623\u0637\u0639\u0646\u0627 \u063a\u0641\u0631\u0627\u0646\u0643 \u0631\u0628\u0646\u0627 \u0648\u0625\u0644\u064a\u0643 \u0627\u0644\u0645\u0635\u064a\u0631"
  },
  {
    "sura_no": 2,
    "aya_no": 286,
    "aya_text_uthmani_pua": "\u200f\ue496 \u200f\ue0d7\u200f\ue75c\u200f\ue2a5 \u200f\ue338\u200f\ue490 \u200f\ue0bf\u200f\ue16e\u200f\ue121\u200f\ue1d9 \u200f\ue361\u200f\ue494 \u200f\ue476\u200f\ue059\u200f\ue15c\u200f\ue1ad\u200f\ue1d9\u200f\ue00c \u200f\ue0ac\u200f\ue1ad\u200f\ue1d9 \u200f\ue0b5\u200f\ue1d9 \u200f\ue0a2\u200f\ue120\u200f\ue875\u200f\ue1f1 \u200f\ue475\u200f\ue07e\u200f\ue189\u200f\ue1bd\u200f\ue1ad\u200f\ue1d9 \u200f\ue0b5\u200f\ue1d9 \u200f\ue338\u200f\ue911\u200f\ue87c\u200f\ue120\u200f\ue0ea\u200f\ue1f1\u200f\ue008 \u200f\ue3d1\u200f\ue022\u200f\ue1a2\u200f\ue1d9 \u200f\ue496 \u200f\ue02f\u200f\ue32b\u200f\ue337\u200f\ue04e\u200f\ue233\u200f\ue0bf\u200f\ue1d6 \u200f\ue361\u200f\ue33f \u200f\ue860\u200f\ue11d\u200f\ue871\u200f\ue1a2\u200f\ue1d6 \u200f\ue35f\u200f\ue471 \u200f\ue35f\u200f\ue051\u200f\ue147\u200f\ue918\u200f\ue0bf\u200f\ue1d9\u200f\ue00c \u200f\ue3d1\u200f\ue022\u200f\ue1a2\u200f\ue1d9 \u200f\ue475\u200f\ue496 \u200f\ue4d1\u200f\ue191\u200f\ue2da \u200f\ue07e\u200f\ue189\u200f\ue1bd\u200f\ue1a2\u200f\ue1d6 \u200f\ue361\u200f\ue6be\u200f\ue6e5\u200f\ue90a \u200f\ue0a2\u200f\ue194\u200f\ue1d9 \u200f\ue559\u200f\ue18a\u200f\ue0f3\u200f\ue315\u200f\ue342 \u200f\ue721 \u200f\ue338\u200f\ue7b1\u200f\ue0de\u200f\ue2f6 \u200f\ue0b3\u200f\ue2fe \u200f\ue097\u200f\ue0ec\u200f\ue187\u200f\ue1a2\u200f\ue1d9\u200f\ue00c \u200f\ue3d1\u200f\ue022\u200f\ue1a2\u200f\ue1d9 \u200f\ue475\u200f\ue496 \u200f\ue4d6\u200f\ue18c\u200f\ue18a\u200f\ue1a2\u200f\ue1d9 \u200f\ue0b5\u200f\ue1d9 \u200f\ue496 \u200f\ue06e\u200f\ue1d9\u200f\ue097\u200f\ue323 \u200f\ue780\u200f\ue1d9 \u200f\ue024\u200f\ue313\u200f\ue344\u200f\ue019 \u200f\ue475\u200f\ue338\u200f\ue080\u200f\ue2a5 \u200f\ue07e\u200f\ue19c\u200f\ue1d9 \u200f\ue475\u200f\ue338\u200f\ue087\u200f\ue16a\u200f\ue249 \u200f\ue780\u200f\ue1d9 \u200f\ue475\u200f\ue338\u200f\ue3ca\u200f\ue55c\u200f\ue1a2\u200f\ue1d6\u200f\ue006 \u200f\ue35f\u200f\ue0c4\u200f\ue1ee \u200f\ue0b5\u200f\ue30b\u200f\ue0ac\u200f\ue1c7\u200f\ue1a2\u200f\ue1d9 \u200f\ue08e\u200f\ue1ca\u200f\ue0c4\u200f\ue6c7\u200f\ue6e2\u200f\ue0bf\u200f\ue1d9 \u200f\ue721 \u200f\ue338\u200f\ue93d\u200f\ue178\u200f\ue30b\u200f\ue44f \u200f\ue338\u200f\ue0ae\u200f\ue923\u200f\ue16a\u200f\ue241\u200f\ue934\u200f\ue2f6 \u200f\uea77",
    "aya_text_emlaey": "\u0644\u0627 \u064a\u0643\u0644\u0641 \u0627\u0644\u0644\u0647 \u0646\u0641\u0633\u0627 \u0625\u0644\u0627 \u0648\u0633\u0639\u0647\u0627 \u0644\u0647\u0627 \u0645\u0627 \u0643\u0633\u0628\u062a \u0648\u0639\u0644\u064a\u0647\u0627 \u0645\u0627 \u0627\u0643\u062a\u0633\u0628\u062a \u0631\u0628\u0646\u0627 \u0644\u0627 \u062a\u0624\u0627\u062e\u0630\u0646\u0627 \u0625\u0646 \u0646\u0633\u064a\u0646\u0627 \u0623\u0648 \u0623\u062e\u0637\u0623\u0646\u0627 \u0631\u0628\u0646\u0627 \u0648\u0644\u0627 \u062a\u062d\u0645\u0644 \u0639\u0644\u064a\u0646\u0627 \u0625\u0635\u0631\u0627 \u0643\u0645\u0627 \u062d\u0645\u0644\u062a\u0647 \u0639\u0644\u0649 \u0627\u0644\u0630\u064a\u0646 \u0645\u0646 \u0642\u0628\u0644\u0646\u0627 \u0631\u0628\u0646\u0627 \u0648\u0644\u0627 \u062a\u062d\u0645\u0644\u0646\u0627 \u0645\u0627 \u0644\u0627 \u0637\u0627\u0642\u0629 \u0644\u0646\u0627 \u0628\u0647 \u0648\u0627\u0639\u0641 \u0639\u0646\u0627 \u0648\u0627\u063a\u0641\u0631 \u0644\u0646\u0627 \u0648\u0627\u0631\u062d\u0645\u0646\u0627 \u0623\u0646\u062a \u0645\u0648\u0644\u0627\u0646\u0627 \u0641\u0627\u0646\u0635\u0631\u0646\u0627 \u0639\u0644\u0649 \u0627\u0644\u0642\u0648\u0645 \u0627\u0644\u0643\u0627\u0641\u0631\u064a\u0646"
  },
  {
    "sura_no": 112,
    "aya_no": 1,
    "aya_text_uthmani_pua": "\u200f\ue096\u200f\ue2da \u200f\ue0c7\u200f\ue309 \u200f\ue338\u200f\ue490 \u200f\ue35f\u200f\ue047\u200f\ue223 \u200f\ue95a",
    "aya_text_emlaey": "\u0642\u0644 \u0647\u0648 \u0627\u0644\u0644\u0647 \u0623\u062d\u062f"
  },
  {
    "sura_no": 112,
    "aya_no": 2,
    "aya_text_uthmani_pua": "\u200f\ue94f\u200f\ue490 \u200f\ue338\u200f\ue0af\u200f\ue12f\u200f\ue194\u200f\ue21f \u200f\ue95b",
    "aya_text_emlaey": "\u0627\u0644\u0644\u0647 \u0627\u0644\u0635\u0645\u062f"
  },
  {
    "sura_no": 112,
    "aya_no": 3,
    "aya_text_uthmani_pua": "\u200f\ue0ac\u200f\ue2ec \u200f\ue0d8\u200f\ue7c3 \u200f\ue475\u200f\ue0ac\u200f\ue2ec \u200f\ue0d7\u200f\ue30f\u200f\ue7a7 \u200f\ue95c",
    "aya_text_emlaey": "\u0644\u0645 \u064a\u0644\u062f \u0648\u0644\u0645 \u064a\u0648\u0644\u062f"
  },
  {
    "sura_no": 112,
    "aya_no": 4,
    "aya_text_uthmani_pua": "\u200f\ue475\u200f\ue0ac\u200f\ue2ec \u200f\ue0d8\u200f\ue920\u200f\ue2fe \u200f\ue7cd\u200f\ue342 \u200f\ue0a0\u200f\ue16b\u200f\ue30a\u200f\ue337 \u200f\ue35f\u200f\ue047\u200f\ue21e \u200f\ue95d",
    "aya_text_emlaey": "\u0648\u0644\u0645 \u064a\u0643\u0646 \u0644\u0647 \u0643\u0641\u0648\u0627 \u0623\u062d\u062f"
  },
  {
    "sura_no": 113,
    "aya_no": 1,
    "aya_text_uthmani_pua": "\u200f\ue096\u200f\ue2da \u200f\ue35f\u200f\ue07d\u200f\ue30f\u200f\ue3c2 \u200f\ue024\u200f\ue245\u200f\ue368 \u200f\ue338\u200f\ue93d\u200f\ue16c\u200f\ue189\u200f\ue2b5 \u200f\ue95a",
    "aya_text_emlaey": "\u0642\u0644 \u0623\u0639\u0648\u0630 \u0628\u0631\u0628 \u0627\u0644\u0641\u0644\u0642"
  },
  {
    "sura_no": 113,
    "aya_no": 2,
    "aya_text_uthmani_pua": "\u200f\ue0b3\u200f\ue2fe \u200f\ue6aa\u200f\ue6d2 \u200f\ue0b5\u200f\ue1d9 \u200f\ue050\u200f\ue189\u200f\ue2b8 \u200f\ue95b",
    "aya_text_emlaey": "\u0645\u0646 \u0634\u0631 \u0645\u0627 \u062e\u0644\u0642"
  },
  {
    "sura_no": 113,
    "aya_no": 3,
    "aya_text_uthmani_pua": "\u200f\ue475\u200f\ue0b3\u200f\ue2fe \u200f\ue6aa\u200f\ue6d2 \u200f\ue7d7\u200f\ue056\u200f\ue2b9 \u200f\ue361\u200f\ue3c1\u200f\ue337 \u200f\ue475\u200f\ue097\u200f\ue1e1 \u200f\ue95c",
    "aya_text_emlaey": "\u0648\u0645\u0646 \u0634\u0631 \u063a\u0627\u0633\u0642 \u0625\u0630\u0627 \u0648\u0642\u0628"
  },
  {
    "sura_no": 113,
    "aya_no": 4,
    "aya_text_uthmani_pua": "\u200f\ue475\u200f\ue0b3\u200f\ue2fe \u200f\ue6aa\u200f\ue6d2 \u200f\ue338\u200f\ue778\u200f\ue811\u200f\ue818\u200f\ue1eb \u200f\ue5e1 \u200f\ue338\u200f\ue0ae\u200f\ue15a\u200f\ue178\u200f\ue21d \u200f\ue95d",
    "aya_text_emlaey": "\u0648\u0645\u0646 \u0634\u0631 \u0627\u0644\u0646\u0641\u0627\u062b\u0627\u062a \u0641\u064a \u0627\u0644\u0639\u0642\u062f"
  },
  {
    "sura_no": 113,
    "aya_no": 5,
    "aya_text_uthmani_pua": "\u200f\ue475\u200f\ue0b3\u200f\ue2fe \u200f\ue6aa\u200f\ue6d2 \u200f\ue047\u200f\ue1d9\u200f\ue056\u200f\ue222 \u200f\ue361\u200f\ue3c1\u200f\ue337 \u200f\ue047\u200f\ue120\u200f\ue221 \u200f\ue95e",
    "aya_text_emlaey": "\u0648\u0645\u0646 \u0634\u0631 \u062d\u0627\u0633\u062f \u0625\u0630\u0627 \u062d\u0633\u062f"
  },
  {
    "sura_no": 114,
    "aya_no": 1,
    "aya_text_uthmani_pua": "\u200f\ue096\u200f\ue2da \u200f\ue35f\u200f\ue07d\u200f\ue30f\u200f\ue3c2 \u200f\ue024\u200f\ue245\u200f\ue368 \u200f\ue338\u200f\ue778\u200f\ue1d9\u200f\ue3e8 \u200f\ue95a",
    "aya_text_emlaey": "\u0642\u0644 \u0623\u0639\u0648\u0630 \u0628\u0631\u0628 \u0627\u0644\u0646\u0627\u0633"
