[
  {
    "sura_no": 2,
    "aya_no": 255,
    "aya_text": "‏‏ ‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
    "aya_text_emlaey": "الله لا إله إلا هو الحي القيوم لا تأخذه سنة ولا نوم له ما في السموات وما في الأرض من ذا الذي يشفع عنده إلا بإذنه يعلم ما بين أيديهم وما خلفهم ولا يحيطون بشيء من علمه إلا بما شاء وسع كرسيه السموات والأرض ولا يئوده حفظهما وهو العلي العظيم"
  },
  {
    "sura_no": 2,
    "aya_no": 285,
    "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
    "aya_text_emlaey": "آمن الرسول بما أنزل إليه من ربه والمؤمنون كل آمن بالله وملائكته وكتبه ورسله لا نفرق بين أحد من رسله وقالوا سمعنا وأطعنا غفرانك ربنا وإليك المصير"
  },
  {
    "sura_no": 2,
    "aya_no": 286,
    "aya_text": "‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
    "aya_text_emlaey": "لا يكلف الله نفسا إلا وسعها لها ما كسبت وعليها ما اكتسبت ربنا لا تؤاخذنا إن نسينا أو أخطأنا ربنا ولا تحمل علينا إصرا كما حملته على الذين من قبلنا ربنا ولا تحملنا ما لا طاقة لنا به واعف عنا واغفر لنا وارحمنا أنت مولانا فانصرنا على القوم الكافرين"
  },
  {
    "sura_no": 112,
    "aya_no": 1,
    "aya_text": "‏‏ ‏‏ ‏‏ ‏‏‏ ‏",
    "aya_text_emlaey": "قل هو الله أحد"
  },
  {
    "sura_no": 112,
    "aya_no": 2,
    "aya_text": "‏‏ ‏‏‏‏‏ ‏",
    "aya_text_emlaey": "الله الصمد"
  },
  {
    "sura_no": 112,
    "aya_no": 3,
    "aya_text": "‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏",
    "aya_text_emlaey": "لم يلد ولم يولد"
  },
  {
    "sura_no": 112,
    "aya_no": 4,
    "aya_text": "‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏",
    "aya_text_emlaey": "ولم يكن له كفوا أحد"
  },
  {
    "sura_no": 113,
    "aya_no": 1,
    "aya_text": "‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
    "aya_text_emlaey": "قل أعوذ برب الفلق"
  },
  {
    "sura_no": 113,
    "aya_no": 2,
    "aya_text": "‏‏ ‏‏ ‏‏ ‏‏‏ ‏",
    "aya_text_emlaey": "من شر ما خلق"
  },
  {
    "sura_no": 113,
    "aya_no": 3,
    "aya_text": "‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏",
    "aya_text_emlaey": "ومن شر غاسق إذا وقب"
  },
  {
    "sura_no": 113,
    "aya_no": 4,
    "aya_text": "‏‏‏ ‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏",
    "aya_text_emlaey": "ومن شر النفاثات في العقد"
  },
  {
    "sura_no": 113,
    "aya_no": 5,
    "aya_text": "‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏",
    "aya_text_emlaey": "ومن شر حاسد إذا حسد"
  },
  {
    "sura_no": 114,
    "aya_no": 1,
    "aya_text": "‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
    "aya_text_emlaey": "قل أعوذ برب الناس"
  },
  {
    "sura_no": 114,
    "aya_no": 2,
    "aya_text": "‏‏‏ ‏‏‏‏ ‏",
    "aya_text_emlaey": "ملك الناس"
  },
  {
    "sura_no": 114,
    "aya_no": 3,
    "aya_text": "‏‏‏ ‏‏‏‏ ‏",
    "aya_text_emlaey": "إله الناس"
  },
  {
    "sura_no": 114,
    "aya_no": 4,
    "aya_text": "‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
    "aya_text_emlaey": "من شر الوسواس الخناس"
  },
  {
    "sura_no": 114,
    "aya_no": 5,
    "aya_text": "‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
    "aya_text_emlaey": "الذي يوسوس في صدور الناس"
  },
  {
    "sura_no": 114,
    "aya_no": 6,
    "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
    "aya_text_emlaey": "من الجنة والناس"
  }
]